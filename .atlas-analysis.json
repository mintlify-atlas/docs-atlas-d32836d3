  "keyFeatures": [
    "Flight search & booking with SerpAPI Google Flights",
    "Real-time flight status tracking with FlightAware AeroAPI",
    "Day-by-day itinerary builder with drag-and-drop",
    "AI-powered trip planning assistant using OpenAI GPT",
    "Transit routing with Google Maps integration",
    "Group travel management with shared itineraries",
    "Multi-currency budget tracking and finance management",
    "Destination and place search"
