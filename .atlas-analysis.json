  "publicApiSurface": [
    "POST /api/flights/serp/search - Search for flights",
    "POST /api/flights/serp/booking-options - Get booking options",
    "POST /api/flights/serp/explore - Explore flight destinations",
    "GET /api/flights/status - Track flight status",
    "POST /api/transit/suggest - Get transit suggestions",
    "POST /api/transit/places/search - Search for places",
    "POST /api/destinations/search - Search destinations",
    "POST /v1/ai/chat - AI chat for trip assistance",
    "POST /v1/ai/planner/chat - AI planner chat",
    "GET /v1/ai/conversations/:tripId - List conversations",
    "GET /v1/ai/conversations/:conversationId/messages - List messages",
    "POST /v1/ai/context/refresh - Refresh AI context"
  ]
